{
  "permissions": {
    "allow": [
      "Bash(npm uninstall:*)",
      "Bash(ls:*)",
      "Bash(volta which:*)",
      "Bash(volta list:*)",
      "Bash(volta run node:*)",
      "Bash(gh pr:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git checkout:*)",
      "Bash(git -c:*)",
      "Bash(pnpm:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(xcodebuildmcp:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Read(./.env)",
      "Read(./.env.*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opusplan",
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  }
}
